{
    "name": "server",
    "module": "src/index.ts",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun src/index.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun src/db/migrate.ts",
        "db:seed": "bun src/db/seed.ts",
        "db:reset": "rm -f data/database.sqlite data/database.sqlite-wal data/database.sqlite-shm && bun run db:migrate && bun run db:seed",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@derecksnotes/shared": "workspace:*",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "drizzle-orm": "^0.45.1",
        "express": "^5.0.0",
        "express-rate-limit": "^8.2.1",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bun": "^1.1.4",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "drizzle-kit": "^0.31.8"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}

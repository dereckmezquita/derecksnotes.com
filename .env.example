# derecksnotes.com
# Copy to .env and fill in values.

# Environment: local | dev | prod
# All URLs, domains, and behavior derive from this single value.
BUILD_ENV=local

# Session signing key. Generate with: openssl rand -base64 32
SESSION_SECRET=

# This username gets auto-elevated to admin on registration.
ADMIN_USERNAME=

# Docker deployment (used by docker-compose.yml)
IMAGE_NAME=derecksnotes
CONTAINER_NAME=derecksnotes
PORT_CLIENT=3000
PORT_SERVER=3001
DATA_PATH=./data
PUBLIC_PATH=./client/public

# Optional: override the default database path
# DATABASE_PATH=./server/data/database.sqlite

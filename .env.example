# derecksnotes.com Environment Configuration
# Copy to .env and fill in values

# Build environment - determines all derived values
# Values: local | dev | prod
BUILD_ENV=local

# Required secrets
SESSION_SECRET=generate-with-openssl-rand-base64-32

# Admin user - this username gets auto-elevated to admin group on registration
ADMIN_USERNAME=

# Docker configuration (for docker-compose)
IMAGE_NAME=derecksnotes
CONTAINER_NAME=derecksnotes
PORT_CLIENT=3000
PORT_SERVER=3001
DATA_PATH=./data
PUBLIC_PATH=./client/public

# Optional overrides (defaults derived from BUILD_ENV)
# DOMAIN=localhost
# DATABASE_PATH=./data/database.sqlite

# See also:
#   client/.env.example  — Next.js-specific variables (NEXT_PUBLIC_*)
#   server/.env.example  — Server-specific variables (DATABASE_PATH, etc.)
